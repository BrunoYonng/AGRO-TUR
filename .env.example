# Execução local: copie para server/.env
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agrotur?schema=public"
JWT_SECRET="troque-por-uma-chave-longa-e-segura"
PORT=3333
CLIENT_URL="http://localhost:5173"

# Docker Compose: copie este arquivo para .env na raiz
APP_PORT=8080
POSTGRES_DB=agrotur
POSTGRES_USER=agrotur
POSTGRES_PASSWORD="troque-esta-palavra-passe"
SEED_DATABASE=true

# IA: OpenAI é usada quando a chave estiver presente.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.6-luna"

# IA multi-provider. Ordem padrão: Gemini -> Groq -> OpenAI -> resposta local.
AI_PROVIDER_ORDER="gemini,groq,openai"
AI_TIMEOUT_MS=12000

# Google AI Studio / Gemini
GOOGLE_API_KEY=""
GOOGLE_MODEL="gemini-2.5-flash"

# Groq
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Link usado na pré-reserva gerada pelo chatbot
WHATSAPP_NUMBER="244923000000"
