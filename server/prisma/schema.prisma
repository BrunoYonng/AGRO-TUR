generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TOURIST
  MANAGER
  FARMER
}

enum BookingStatus {
  PENDING
  APPROVED
  CANCELLED
}

enum AreaType {
  PLANTATION
  ANIMALS
  LEISURE
  SERVICE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(TOURIST)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Experience {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  price       Decimal   @db.Decimal(10, 2)
  capacity    Int
  date        DateTime
  duration    String?
  imageUrl    String?
  active      Boolean   @default(true)
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id           String        @id @default(cuid())
  guestName    String
  guestEmail   String?
  guestPhone   String
  guests       Int           @default(1)
  totalAmount  Decimal       @db.Decimal(10, 2)
  visitDate    DateTime
  status       BookingStatus @default(PENDING)
  notes        String?
  experienceId String
  experience   Experience    @relation(fields: [experienceId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Product {
  id        String   @id @default(cuid())
  name      String
  sku       String   @unique
  price     Decimal  @db.Decimal(10, 2)
  stock     Int      @default(0)
  unit      String   @default("un")
  sold      Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FarmArea {
  id          String   @id @default(cuid())
  name        String
  type        AreaType
  description String
  geojson     Json
  public      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatLog {
  id        String   @id @default(cuid())
  sessionId String?
  message   String
  response  String
  createdAt DateTime @default(now())

  @@index([sessionId])
}
