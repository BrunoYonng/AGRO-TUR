# Execução local: copie para server/.env
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agrotur?schema=public"
JWT_SECRET="troque-por-uma-chave-longa-e-segura"
PORT=3333
CLIENT_URL="http://localhost:5173"

# Docker Compose: copie este arquivo para .env na raiz
APP_PORT=8080
POSTGRES_DB=agrotur
POSTGRES_USER=agrotur
POSTGRES_PASSWORD="troque-esta-palavra-passe"
SEED_DATABASE=true

# IA: OpenAI é usada quando a chave estiver presente.
OPENAI_API_KEY=""
